# --- HTTP server ---
# Bind to localhost by default. Only expose beyond 127.0.0.1 behind a TLS reverse proxy.
HOST=127.0.0.1
PORT=3000

# --- Auth ---
# CHANGE THIS in production. Used to sign JWT access tokens.
JWT_SECRET=dev-only-change-me
# Access token lifetime (seconds). 12h by default.
JWT_TTL=43200

# Seed user created on first boot if the users table is empty.
SEED_USERNAME=admin
SEED_PASSWORD=changeme

# --- CS2 process ---
# Path to the CS2 dedicated server binary (executable ONLY, no args here).
#   .../Counter-Strike Global Offensive/game/bin/linuxsteamrt64/cs2
# For local backend development you do NOT need CS2 at all — point this at any
# long-lived process to exercise the full spawn/reconcile/stop lifecycle, e.g.:
#   CS2_BIN=sleep  +  CS2_EXTRA_ARGS=infinity
CS2_BIN=/home/steam/cs2/game/bin/linuxsteamrt64/cs2

# Extra args appended after the generated CS2 args. Pipe-separated ('|') so
# values may contain spaces without shell-quoting headaches. Leave empty for
# real CS2; used for the dev mock (e.g. CS2_BIN=sleep + CS2_EXTRA_ARGS=infinity)
# or extra prod flags.
CS2_EXTRA_ARGS=

# Base UDP port; servers get BASE_PORT, BASE_PORT+1, ... as they launch.
BASE_PORT=27015

# Firewall management: on|off. Uses ufw and requires root.
# Keep OFF for local dev to avoid privilege prompts and noise.
FIREWALL=off

# GSLT token for public/internet servers (Linux prod). Leave empty for local/LAN.
# Passed to cs2 as +sv_setsteamaccount <token>.
GSLT_TOKEN=

# Path to the SQLite database file.
DB_PATH=./data/launcher.db

# Per-launch CS2 stdout/stderr logs go here as <port>-<launchedAt>.log.
LOG_DIR=./data/logs

# CSSharp plugins directory — usually the CS2 install's
# csgo/addons/counterstrikesharp/plugins/. Leave empty to disable the /plugins
# routes; set to a path to enable install/list/delete via the client.
PLUGINS_DIR=
